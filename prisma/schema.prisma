generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Vendor {
  id        Int         @id @default(autoincrement())
  username  String      @unique
  password  String
  name      String
  furniture Furniture[]
}

model Furniture {
  id        Int    @id @default(autoincrement())
  name      String
  price     Float
  model     String
  vendorId  Int
  vendor    Vendor @relation(fields: [vendorId], references: [id])
  purchases Int    @default(0)
}
